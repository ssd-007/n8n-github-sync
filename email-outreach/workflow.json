      "id": "61eecaa9-abb4-4dbd-b0fd-1f0fa8f88a8d",
      "name": "Apollo Get Decision-Maker"
    },
    {
      "parameters": {
        "jsCode": "// Strip all HTML tags and get plain text (like Make.com HTML to Text)\nconst htmlContent = $input.first().json.body;\nconst textOnly = htmlContent.replace(/<[^>]*>/g, '').replace(/\\s+/g, ' ').trim();\n\n// Apply the regex pattern from Make.com (convert to JavaScript regex)\nconst cleanedText = textOnly.replace(/(\\^.*\\*.*\\$\\\\n\\?|\\\\n|\\\\N|\\[.*\\?\\]|https\\?:\\/\\/\\S+|\\\\n\\s*\\\\n)/g, '');\n\nreturn [{\n  json: {\n    text: textOnly\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2944,
        416
      ],
      "id": "dc0adaff-1366-4031-8467-2135180ed74f",
      "name": "HTML to Text"
    },
    {
