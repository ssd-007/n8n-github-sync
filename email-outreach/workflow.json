              "value": "08eSXMxJtXn22UlcgEl9jQ"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"q_organization_domains_list\": [\"{{ $json.website }}\"],\n  \"person_titles\": [\"CEO\", \"Founder\", \"Director\"],\n  \"person_seniorities\": [\"cxo\", \"director\", \"vp\"],\n  \"contact_email_status\": \"verified\",\n  \"per_page\": 1\n}",
        "options": {}
