        "url": "https://scrapeninja.p.rapidapi.com/scrape",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Rapidapi-Key",
              "value": "f54e983d2dmshdf7f45446c832a6p1bd08bjsn62ac116b4ae1"
            },
            {
              "name": "X-Rapidapi-Host",
              "value": "scrapeninja.p.rapidapi.com"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{ $('Get Website').item.json.result.website.replace('http:', 'https:') }}\",\n  \"js\": false,\n  \"premium\": false,\n  \"wait\": 10000,\n  \"block_resources\": [\"image\", \"media\", \"font\"],\n  \"stealth\": true\n}",
        "options": {}
      },
